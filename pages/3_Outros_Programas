@st.cache_data(ttl=86400) # Mantém a lista de programas em cache por 1 dia
def obter_programas_ufsc():
    """Conecta ao repositório da UFSC e lista todas as coleções disponíveis."""
    try:
        sickle = Sickle('https://repositorio.ufsc.br/oai/request')
        sets = sickle.ListSets()
        colecoes = {}
        for s in sets:
            # Filtra apenas Coleções (ignora comunidades agregadoras globais)
            if s.setSpec.startswith('col_'):
                colecoes[s.setName] = s.setSpec
        # Ordena alfabeticamente
        return dict(sorted(colecoes.items()))
    except Exception as e:
        st.error(f"Erro ao conectar com a UFSC: {e}")
        return {}

def extrair_melhor_ano(lista_datas):
    if not lista_datas: return None
    anos = [int(m) for d in lista_datas for m in re.findall(r'\b(19\d{2}|20\d{2})\b', str(d))]
    return str(min(anos)) if anos else None

def normalizar_nome(nome):
    if not nome: return ""
    return ''.join(c for c in unicodedata.normalize('NFD', nome) if unicodedata.category(c) != 'Mn').strip().title()

def normalizar_palavra_chave(pk):
    if not pk: return ""
    pk = ''.join(c for c in unicodedata.normalize('NFD', pk.lower().strip()) if unicodedata.category(c) != 'Mn')
    return pk

def identificar_nivel(tipos, titulo=""):
    tipos_str = " ".join(tipos).lower()
    titulo_lower = titulo.lower()
    if 'doctoral' in tipos_str or 'tese' in tipos_str or 'tese' in titulo_lower: return 'Tese (Doutorado)'
    if 'master' in tipos_str or 'disserta' in tipos_str or 'disserta' in titulo_lower: return 'Dissertação (Mestrado)'
    return 'Outros'

def realizar_extracao(set_spec, status_placeholder):
    """Realiza a extração massiva com feedback em tempo real para o usuário."""
    sickle = Sickle('https://repositorio.ufsc.br/oai/request')
    try:
        records = sickle.ListRecords(metadataPrefix='oai_dc', set=set_spec)
    except Exception as e:
        st.error("A coleção parece estar vazia ou a UFSC bloqueou o acesso temporário.")
        return []

    dados_extraidos = []
    ignorados = 0
    titulos_vistos = set()

    for i, record in enumerate(records):
        # Atualiza a interface a cada 50 registos para o utilizador não achar que travou
        if i % 50 == 0:
            status_placeholder.info(f"⏳ Extraindo dados diretamente do servidor da UFSC... Já processados: **{i}** documentos.")

        if record.header.deleted or not record.metadata:
            ignorados += 1; continue
            
        try:
            meta = record.metadata
            titulo = meta.get('title', [''])[0].strip()
            if not titulo or titulo in titulos_vistos: continue
            titulos_vistos.add(titulo)
            
            autores = [normalizar_nome(a) for a in meta.get('creator', []) if a.strip()]
            ano_real = extrair_melhor_ano(meta.get('date', []))
            nivel = identificar_nivel(meta.get('type', []), titulo)
            
            contrib = [normalizar_nome(c) for c in meta.get('contributor', []) if "universidade" not in c.lower() and "ufsc" not in c.lower()]
            orientador = contrib[0] if len(contrib) > 0 else None
            co_orientadores = contrib[1:] if len(contrib) > 1 else []
            
            pks = list(set([normalizar_palavra_chave(pk) for pk in meta.get('subject', []) if pk]))
            
            dados_extraidos.append({
                'titulo': titulo, 'nivel_academico': nivel, 'autores': autores,
                'orientador': orientador, 'co_orientadores': co_orientadores,
                'possui_coorientador': len(co_orientadores) > 0, 'palavras_chave': pks, 'ano': ano_real
            })
        except:
            ignorados += 1

    status_placeholder.success(f"✅ Extração concluída! {len(dados_extraidos)} documentos válidos capturados.")
    return dados_extraidos


# --- FUNÇÕES ANALÍTICAS E REDES ---
@st.cache_data
def obter_dataframe_metricas(dados_recorte):
    G = nx.Graph()
    for tese in dados_recorte:
        doc = tese['titulo']
        G.add_node(doc, tipo='Documento')
        for autor in tese.get('autores', []):
            G.add_node(autor, tipo='Autor')
            G.add_edge(autor, doc)
        if tese.get('orientador'):
            G.add_node(tese['orientador'], tipo='Orientador')
            G.add_edge(tese['orientador'], doc)
        for pk in tese.get('palavras_chave', []):
            G.add_node(pk, tipo='Conceito')
            G.add_edge(doc, pk)

    deg_cent = nx.degree_centrality(G)
    bet_cent = nx.betweenness_centrality(G)
    lista = [{'Entidade (Nó)': n, 'Categoria': attr.get('tipo', 'Outro'), 'Grau Absoluto': G.degree(n), 'Degree Centrality': deg_cent[n], 'Betweenness': bet_cent[n]} for n, attr in G.nodes(data=True)]
    return pd.DataFrame(lista)

@st.cache_resource
def gerar_html_pyvis(dados_recorte, metodo_cor, metodo_tamanho):
    G = nx.Graph()
    for tese in dados_recorte:
        doc = tese['titulo']
        G.add_node(doc, tipo='Documento', nivel=tese.get('nivel_academico', 'N/A'), ano=tese.get('ano', 'N/A'), orientador=tese.get('orientador', 'N/A'))
        if tese.get('orientador'):
            G.add_node(tese['orientador'], tipo='Orientador')
            G.add_edge(tese['orientador'], doc)
        for pk in tese.get('palavras_chave', []):
            G.add_node(pk, tipo='Conceito')
            G.add_edge(doc, pk)

    deg_cent = nx.degree_centrality(G)
    bet_cent = nx.betweenness_centrality(G)
    grau_abs = dict(G.degree())

    max_deg = max(deg_cent.values()) if deg_cent else 1
    max_bet = max(bet_cent.values()) if bet_cent else 1
    max_abs = max(grau_abs.values()) if grau_abs else 1

    legendas = []
    if metodo_cor != "Original (Categoria)":
        comunidades = nx_comm.louvain_communities(G) if metodo_cor == "Comunidades (Louvain)" else nx_comm.greedy_modularity_communities(G)
        paleta = ['#e6194b', '#3cb44b', '#ffe119', '#4363d8', '#f58231', '#911eb4', '#46f0f0', '#f032e6', '#bcf60c', '#fabebe']
        for i, comm in enumerate(comunidades):
            cor = paleta[i % len(paleta)]
            legendas.append({"id": i+1, "cor": cor, "tamanho": len(comm)})
            for n in comm: G.nodes[n]['color'] = cor

    for n, attrs in G.nodes(data=True):
        tipo = attrs.get('tipo', 'Desconhecido')
        if metodo_tamanho == "Grau Absoluto": tam = 10 + (grau_abs[n]/max_abs)*50
        elif metodo_tamanho == "Degree Centrality": tam = 10 + (deg_cent[n]/max_deg)*50
        elif metodo_tamanho == "Betweenness": tam = 10 + (bet_cent[n]/max_bet)*50
        else: tam = 25 if tipo == 'Documento' else 15
            
        attrs.update({'size': tam, 'title': f"<b>{n}</b><br>Tipo: {tipo}<br>Grau: {grau_abs[n]}<br>Betweenness: {bet_cent[n]:.4f}"})
        if metodo_cor == "Original (Categoria)":
            attrs['color'] = '#E74C3C' if tipo == 'Documento' else '#F39C12' if tipo == 'Orientador' else '#2ECC71'

    net = Network(height='600px', width='100%', bgcolor='#222222', font_color='white', directed=False)
    net.from_nx(G)
    net.set_options('{"interaction": {"hover": true, "selectConnectedEdges": true}}')
    path = "temp_pyvis.html"
    net.save_graph(path)
    return path, G.number_of_nodes(), G.number_of_edges(), legendas


